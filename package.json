{
  "name": "slopjective-c",
  "private": true,
  "devDependencies": {
    "markdownlint-cli2": "^0.20.0",
    "prettier": "^3.2.5"
  },
  "scripts": {
    "lint": "npm run check:task-hygiene && npm run check:md:all",
    "test": "python scripts/objc3c_public_workflow_runner.py test-default",
    "test:fast": "python scripts/objc3c_public_workflow_runner.py test-fast",
    "test:smoke": "python scripts/objc3c_public_workflow_runner.py test-smoke",
    "test:ci": "python scripts/objc3c_public_workflow_runner.py test-ci",
    "build": "python scripts/objc3c_public_workflow_runner.py build-default",
    "build:spec": "python scripts/objc3c_public_workflow_runner.py build-spec",
    "build:objc3c-native": "python scripts/objc3c_public_workflow_runner.py build-native-binaries",
    "build:objc3c-native:contracts": "python scripts/objc3c_public_workflow_runner.py build-native-contracts",
    "build:objc3c-native:full": "python scripts/objc3c_public_workflow_runner.py build-native-full",
    "build:objc3c-native:reconfigure": "python scripts/objc3c_public_workflow_runner.py build-native-reconfigure",
    "package:objc3c-native:runnable-toolchain": "python scripts/objc3c_public_workflow_runner.py package-runnable-toolchain",
    "compile:objc3c": "python scripts/objc3c_public_workflow_runner.py compile-objc3c",
    "proof:objc3c": "python scripts/objc3c_public_workflow_runner.py proof-objc3c",
    "test:objc3c": "python scripts/objc3c_public_workflow_runner.py test-recovery",
    "test:objc3c:execution-smoke": "python scripts/objc3c_public_workflow_runner.py test-execution-smoke",
    "test:objc3c:execution-replay-proof": "python scripts/objc3c_public_workflow_runner.py test-execution-replay",
    "test:objc3c:runtime-acceptance": "python scripts/objc3c_public_workflow_runner.py test-runtime-acceptance",
    "test:objc3c:runtime-architecture": "python scripts/objc3c_public_workflow_runner.py validate-runtime-architecture",
    "test:objc3c:block-arc-conformance": "python scripts/objc3c_public_workflow_runner.py validate-block-arc-conformance",
    "test:objc3c:object-model-conformance": "python scripts/objc3c_public_workflow_runner.py validate-object-model-conformance",
    "test:objc3c:storage-reflection-conformance": "python scripts/objc3c_public_workflow_runner.py validate-storage-reflection-conformance",
    "test:objc3c:runnable-bootstrap": "python scripts/objc3c_public_workflow_runner.py validate-runnable-bootstrap",
    "test:objc3c:runnable-block-arc": "python scripts/objc3c_public_workflow_runner.py validate-runnable-block-arc",
    "test:objc3c:runnable-object-model": "python scripts/objc3c_public_workflow_runner.py validate-runnable-object-model",
    "test:objc3c:runnable-storage-reflection": "python scripts/objc3c_public_workflow_runner.py validate-runnable-storage-reflection",
    "test:objc3c:fixture-matrix": "python scripts/objc3c_public_workflow_runner.py test-fixture-matrix",
    "test:objc3c:negative-expectations": "python scripts/objc3c_public_workflow_runner.py test-negative-expectations",
    "test:objc3c:full": "python scripts/objc3c_public_workflow_runner.py test-full",
    "test:objc3c:nightly": "python scripts/objc3c_public_workflow_runner.py test-nightly",
    "lint:spec": "python scripts/objc3c_public_workflow_runner.py lint-spec",
    "check:task-hygiene": "python scripts/ci/run_task_hygiene_gate.py",
    "check:objc3c:boundaries": "python scripts/check_objc3c_dependency_boundaries.py --strict",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "format:md": "prettier --write \"**/*.md\"",
    "check:md": "prettier --check \"**/*.md\"",
    "check:md:all": "npm run build:spec && npm run check:md"
  }
}
