{
  "contract_id": "objc3c.stdlib.program_surface.v1",
  "schema_version": 1,
  "workspace_contract": "stdlib/workspace.json",
  "package_surface": "stdlib/package_surface.json",
  "advanced_architecture": "stdlib/advanced_architecture.json",
  "stdlib_readme": "stdlib/README.md",
  "runbook": "docs/runbooks/objc3c_stdlib_program.md",
  "site_entry": "site/src/index.body.md",
  "tutorial_readme": "docs/tutorials/README.md",
  "getting_started_readme": "docs/tutorials/getting_started.md",
  "comparison_readme": "docs/tutorials/objc2_swift_cpp_comparison.md",
  "showcase_readme": "showcase/README.md",
  "showcase_portfolio": "showcase/portfolio.json",
  "guided_walkthrough_manifest": "showcase/tutorial_walkthrough.json",
  "machine_output_root": "tmp/artifacts/stdlib",
  "machine_report_root": "tmp/reports/stdlib",
  "package_stage_root": "tmp/pkg/objc3c-native-runnable-toolchain",
  "publish_model": "shared-runnable-toolchain-bundle-carries-live-stdlib-docs-tutorials-site-and-showcase-surfaces",
  "publish_inputs": [
    "stdlib/README.md",
    "docs/runbooks/objc3c_stdlib_program.md",
    "docs/tutorials/README.md",
    "docs/tutorials/getting_started.md",
    "docs/tutorials/objc2_swift_cpp_comparison.md",
    "showcase/README.md",
    "showcase/portfolio.json",
    "showcase/tutorial_walkthrough.json",
    "site/src/index.body.md"
  ],
  "staged_manifest_fields": [
    "stdlib_program_surface",
    "stdlib_program_command_surfaces",
    "stdlib_program_publish_inputs",
    "stdlib_program_examples"
  ],
  "public_actions": [
    "check-documentation-surface",
    "check-showcase-surface",
    "validate-getting-started",
    "validate-showcase",
    "validate-runnable-showcase",
    "inspect-capability-explorer",
    "package-runnable-toolchain"
  ],
  "command_surfaces": {
    "check_documentation_surface": "npm run check:docs:surface",
    "check_showcase_surface": "npm run check:showcase:surface",
    "validate_getting_started": "npm run test:getting-started",
    "validate_showcase": "npm run test:showcase",
    "validate_runnable_showcase": "npm run test:showcase:e2e",
    "inspect_capability_explorer": "npm run inspect:objc3c:capabilities",
    "package_runnable_toolchain": "npm run package:objc3c-native:runnable-toolchain"
  },
  "onboarding_policy": {
    "entry_order": [
      "repo-health",
      "single-example-compile",
      "showcase-example-selection",
      "migration-or-comparison-doc"
    ],
    "runnable_claim_rule": "only capabilities backed by checked-in compile and shared validation flows may be presented as runnable-now stories",
    "comparison_claim_rule": "not-yet-runnable capabilities must be framed as actor-shaped comparison or migration guidance rather than runnable parity claims",
    "command_truth_rule": "package.json and scripts/objc3c_public_workflow_runner.py define the authoritative public commands",
    "machine_noise_rule": "tmp artifacts and legacy redirect material may not appear as the primary onboarding route"
  },
  "capability_demo_examples": [
    {
      "id": "auroraBoard",
      "source": "showcase/auroraBoard/main.objc3",
      "workspace_manifest": "showcase/auroraBoard/workspace.json",
      "stdlib_followup_modules": [
        "objc3.core",
        "objc3.errors",
        "objc3.keypath"
      ],
      "story_capabilities": [
        "categories",
        "reflection",
        "synthesized-behaviors"
      ]
    },
    {
      "id": "signalMesh",
      "source": "showcase/signalMesh/main.objc3",
      "workspace_manifest": "showcase/signalMesh/workspace.json",
      "stdlib_followup_modules": [
        "objc3.concurrency",
        "objc3.system"
      ],
      "story_capabilities": [
        "status-bridging",
        "actor-shaped-messaging",
        "runtime-messaging"
      ]
    },
    {
      "id": "patchKit",
      "source": "showcase/patchKit/main.objc3",
      "workspace_manifest": "showcase/patchKit/workspace.json",
      "stdlib_followup_modules": [
        "objc3.keypath",
        "objc3.system"
      ],
      "story_capabilities": [
        "derives",
        "macros",
        "property-behaviors",
        "interop"
      ]
    }
  ],
  "working_scope": [
    "reader-facing stdlib onboarding rooted in docs/tutorials",
    "capability-driven example routing rooted in showcase",
    "site entrypoints that route readers into the live stdlib and showcase surfaces",
    "shared validation and packaging through the existing public runner and runnable toolchain bundle"
  ],
  "non_goals": [
    "milestone-local tutorial wrappers",
    "duplicate example trees outside showcase",
    "machine-owned documentation under tmp",
    "a second stdlib demo packaging flow outside the existing runnable toolchain bundle"
  ]
}
