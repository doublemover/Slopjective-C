module objc3_errors_smoke;

fn objc3_errors_result_ok_tag() {
  return 1;
}

fn objc3_errors_result_err_tag() {
  return 2;
}

fn objc3_errors_result_is_ok(tag: i32) {
  if (tag == 1) {
    return 1;
  } else {
    return 0;
  }
}

fn objc3_errors_option_to_result_tag(flag: i32) {
  if (flag) {
    return 1;
  } else {
    return 2;
  }
}

fn objc3_errors_result_bridge_diagnostic(flag: i32, tag: i32) {
  if (objc3_errors_option_to_result_tag(flag) == tag) {
    return 0;
  } else {
    return 30601;
  }
}

fn objc3_errors_result_unwrap_or(tag: i32, value: i32, fallback: i32) {
  if (tag == 1) {
    return value;
  } else {
    return fallback;
  }
}

fn objc3_errors_result_error_or(tag: i32, code: i32, fallback: i32) {
  if (tag == 2) {
    return code;
  } else {
    return fallback;
  }
}

fn objc3_errors_ok_or_code(value: i32, fallback: i32) {
  if (value) {
    return value;
  } else {
    return fallback;
  }
}

fn objc3_errors_or_throw_code(value: i32, fallback: i32) {
  if (value) {
    return value;
  } else {
    return fallback;
  }
}

fn objc3_errors_text_data_compatibility_score(unit_count: i32, byte_count: i32) {
  return unit_count + byte_count;
}

fn objc3_errors_text_data_compatibility_diagnostic(unit_count: i32, byte_count: i32) {
  if (unit_count == byte_count) {
    return 0;
  } else {
    return 30602;
  }
}

fn main() {
  return objc3_errors_result_ok_tag()
    + objc3_errors_result_err_tag()
    + objc3_errors_result_is_ok(1)
    + objc3_errors_option_to_result_tag(0)
    + objc3_errors_result_bridge_diagnostic(0, 1)
    + objc3_errors_result_unwrap_or(1, 5, 6)
    + objc3_errors_result_error_or(2, 7, 8)
    + objc3_errors_ok_or_code(0, 2)
    + objc3_errors_or_throw_code(3, 4)
    + objc3_errors_text_data_compatibility_score(5, 6)
    + objc3_errors_text_data_compatibility_diagnostic(5, 6);
}
