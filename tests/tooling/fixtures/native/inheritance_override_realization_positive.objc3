module inheritanceOverrideRealizationPositive;

@interface Root
@property (readonly) i32 token;
- (i32) ping;
+ (i32) shared;
@end

@implementation Root
@property (readonly) i32 token;
- (i32) ping {
  return 1;
}
+ (i32) shared {
  return 2;
}
@end

@interface Widget : Root
@property (readonly) i32 token;
- (i32) ping;
+ (i32) shared;
@end

@implementation Widget
@property (readonly) i32 token;
- (i32) ping {
  return [super ping] + 3;
}
+ (i32) shared {
  return 4;
}
@end

fn main() -> i32 {
  return [Widget shared];
}
