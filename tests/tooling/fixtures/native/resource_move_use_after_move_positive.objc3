module m271b002;

fn moveSurface(value: id) -> i32 {
  @cleanup(ReleaseTemp) let temp = 1;
  @resource(CloseFd, invalid: -1) let fd = 3;
  let peer = value;
  let block = ^[move temp, unowned peer, weak value] (i32 x) {
    let weakRef = value;
    let peerRef = peer;
    return x + temp;
  };
  return fd;
}
