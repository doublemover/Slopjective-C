module m267_live_error_runtime_integration_positive;

fn risky(value: i32) throws -> i32 {
  if (value == 1) {
    throw 31;
  }
  return value + 9;
}

fn mapStatus(status: i32) -> NSError {
  return status + 40;
}

fn bridgeStatus(value: i32, error: NSError*) -> i32 __attribute__((objc_status_code(success: 0, error_type: NSError, mapping: mapStatus))) {
  if (value == 2) {
    return 5;
  }
  return 0;
}

fn runCase() -> i32 {
  let direct = try! risky(0);
  do {
