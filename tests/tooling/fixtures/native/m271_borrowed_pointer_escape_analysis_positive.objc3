module m271b003;

extern fn ConsumeBorrowed(bytes: borrowed id *) -> void;
extern fn BorrowWindow(owner: id) -> borrowed id *
    __attribute__((objc_returns_borrowed(owner_index=0)));

fn borrowedOk(owner: id, bytes: borrowed id *) -> i32 {
  ConsumeBorrowed(bytes);
  let window = BorrowWindow(owner);
  let mirror = window;
  return 0;
}
