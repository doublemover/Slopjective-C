module Part9C003Provider;

extern fn replay_proof_step() -> i32;
extern fn race_guard_lock() -> i32;
extern fn task_handoff_ready() -> i32;
extern fn actor_isolated_step() -> i32;
extern fn actor_mailbox_enqueue(handle: i32, value: i32) -> i32;
extern fn actor_mailbox_drain_next(handle: i32) -> i32;
extern fn actor_nonisolated_entry(value: i32) -> i32;

actor class ProviderMailbox
- (i32)run:(i32)seed async __attribute__((objc_executor(main)));
- (i32)token:(i32)seed __attribute__((objc_nonisolated));
@end

@implementation ProviderMailbox
- (i32)run:(i32)seed async __attribute__((objc_executor(main))) {
  replay_proof_step();
  race_guard_lock();
  task_handoff_ready();
  actor_isolated_step();
  let queued = actor_mailbox_enqueue(seed, seed + 1);
  task_handoff_ready();
  let drained = actor_mailbox_drain_next(seed);
  return queued + drained;
}

- (i32)token:(i32)seed __attribute__((objc_nonisolated)) {
  replay_proof_step();
  race_guard_lock();
  return actor_nonisolated_entry(seed);
}
@end

__attribute__((objc_direct_members, objc_final, objc_sealed))
@interface PolicyBox
+ (i32)implicitDirect;
+ (i32)dynamicEscape __attribute__((objc_dynamic));
+ (i32)explicitDirect __attribute__((objc_direct));
+ (i32)callers;
@end

@implementation PolicyBox
+ (i32)implicitDirect { return 3; }
+ (i32)dynamicEscape __attribute__((objc_dynamic)) { return 4; }
+ (i32)explicitDirect __attribute__((objc_direct)) { return 5; }
+ (i32)callers {
  return [self implicitDirect] + [self dynamicEscape] + [PolicyBox explicitDirect];
}
@end

fn main() -> i32 {
  return [PolicyBox callers];
}
