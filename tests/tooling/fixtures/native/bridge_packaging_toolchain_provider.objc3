module m274_bridge_packaging_toolchain_provider;

extern fn ffiInbound(selector: SEL) -> i32 __attribute__((objc_foreign, objc_import_module(named("BridgeProviderKit"))));
extern fn ffiHeaderBridge(value: i32) -> i32 __attribute__((objc_header_name(named("BridgeProvider.h")), objc_cxx_name(named("BridgeProviderShim"))));

fn main() -> i32 {
  return ffiInbound(nil) + ffiHeaderBridge(3);
}