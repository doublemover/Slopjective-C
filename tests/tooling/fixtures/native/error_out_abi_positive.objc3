module m267_error_out_abi_positive;

fn risky(value: i32) throws -> i32 {
  if (value == 1) {
    throw 34;
  }
  return value + 10;
}

fn bridgeMapping(status: i32) -> NSError {
  return status + 40;
}

fn bridge(value: i32, error: NSError*) -> i32 __attribute__((objc_status_code(success: 0, error_type: NSError, mapping: bridgeMapping))) {
  if (value == 2) {
    return 5;
  }
  return 0;
}

fn recover() throws -> i32 {
  let direct = try risky(0);
  let maybeValue = try? bridge(2, 0);
  let forced = try! risky(3);
  do {
    let bridged = try bridge(2, 0);
    return bridged;
  } catch (NSError* error) {
    return direct + maybeValue + forced + error;
  } catch {
    return 999;
  }
}

fn bubble() throws -> i32 {
  return try risky(1);
}

fn main() -> i32 {
  let recovered = try! recover();
  do {
    let bubbled = try bubble();
    return recovered + bubbled;
  } catch (NSError* error) {
    return recovered + error;
  } catch {
    return 0;
  }
}
