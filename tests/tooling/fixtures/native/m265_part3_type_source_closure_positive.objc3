module part3TypeSourceClosure;

@protocol SourceValue
@required
@property (readonly) id requiredToken;
- (id<SourceValue>*?)requiredNode;
@optional
@property (readonly) id optionalToken;
- (id<SourceValue>*!)optionalNode;
@end

fn choose(flag: bool, when_true: id<SourceValue>*?, when_false: id<SourceValue>*!) -> id<SourceValue>*? {
  if (flag) {
    return when_true;
  }
  return when_false;
}

fn main() -> i32 {
  return choose(true, 7, 5);
}
