async fn groupedWorker() -> i32 __attribute__((objc_executor(global))) {
  task_spawn_child();
  with_task_group_scope();
  task_group_add_task();
  if (task_runtime_cancelled_value()) {
    return task_group_cancel_all();
  }
  return await task_group_wait_next();
}

async fn detachedWorker() -> i32 __attribute__((objc_executor(named("com.example.group")))) {
  detached_task_create();
  if (task_runtime_cancelled_value()) {
    return task_runtime_on_cancel();
  }
  return 7;
}

async fn runTask() -> i32 __attribute__((objc_executor(named("com.example.main")))) {
