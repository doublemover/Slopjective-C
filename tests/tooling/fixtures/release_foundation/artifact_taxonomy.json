{
  "contract_id": "objc3c.release.foundation.artifact.taxonomy.v1",
  "surface_kind": "release-artifact-taxonomy",
  "canonical_release_payload": "staged-runnable-toolchain-bundle",
  "artifact_classes": [
    {
      "artifact_id": "runnable-package-root",
      "role": "payload-root",
      "truthfulness_boundary": "machine-generated under tmp/pkg from the repo-local package script"
