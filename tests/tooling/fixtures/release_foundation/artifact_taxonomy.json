    {
      "artifact_id": "runnable-package-manifest",
      "role": "payload-layout-manifest",
      "truthfulness_boundary": "machine-generated by scripts/package_objc3c_runnable_toolchain.ps1"
    },
    {
      "artifact_id": "release-manifest",
      "role": "selected-release-payload-manifest",
      "truthfulness_boundary": "machine-generated from the staged runnable package and checked-in release contracts"
    },
    {
      "artifact_id": "release-sbom",
      "role": "component-inventory",
      "truthfulness_boundary": "machine-generated from the release manifest and selected payload entries"
    },
    {
      "artifact_id": "release-attestation",
      "role": "provenance-binding",
