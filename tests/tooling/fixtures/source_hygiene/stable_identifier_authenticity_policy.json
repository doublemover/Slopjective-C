{
  "contract_id": "objc3c.source_hygiene.stable_identifier_authenticity_policy.v1",
  "schema_version": 1,
  "scope": {
    "product_surface_roots": [
      "README.md",
      "CONTRIBUTING.md",
      "site/src/",
      "site/index.md",
      "docs/tutorials/",
      "docs/runbooks/",
      "docs/objc3c-native/src/",
      "docs/objc3c-native.md",
      "showcase/",
      "stdlib/",
      "schemas/",
      "scripts/",
      "native/objc3c/src/"
    ],
    "generated_truth_files": [
      "site/index.md",
      "docs/objc3c-native.md",
      "docs/runbooks/objc3c_public_command_surface.md"
    ],
    "archive_only_roots": [
      "tmp/planning/",
      "tmp/github-publish/",
      "tmp/archive/",
      "docs/reference/"
    ]
  },
  "stable_identifier_policy": {
    "durable_identifier_regex": "^objc3c\\.[a-z][a-z0-9]*(\\.[a-z][a-z0-9]*)+\\.v[0-9]+$",
    "schema_filename_regex": "^objc3c-[a-z0-9-]+-v[0-9]+\\.schema\\.json$",
    "annotation_families": [
      "surface_id",
      "artifact_family_id",
      "fixture_family_id",
      "report_family_id",
      "historical_ref"
    ],
    "forbidden_product_tokens": [
      "M###",
      "[M###]",
      "Lane-A",
      "Lane-B",
      "Lane-C",
      "Lane-D",
      "Lane-E",
      "workpack iteration",
      "closeout signoff"
    ],
    "replacement_examples": {
      "runtime_dispatch_surface": "objc3c.runtime.classdispatch.selectorpool.v1",
      "property_accessor_surface": "objc3c.lowering.propertyaccessor.synthesized.v1",
      "native_source_hygiene_report": "objc3c.report.sourcehygiene.native.v1",
      "synthetic_ll_fixture_family": "objc3c.fixture.synthetic.replayll.v1",
      "replay_manifest_family": "objc3c.artifact.replaymanifest.frontend.v1"
    }
  },
  "authenticity_classes": {
    "generated_truth": {
      "claim_strength": "authoritative_checked_in_surface",
      "description": "checked-in generated outputs that are canonical user or operator truth surfaces",
      "allowed_roots": [
        "site/index.md",
        "docs/objc3c-native.md",
        "docs/runbooks/objc3c_public_command_surface.md"
      ],
      "must_not_contain_milestone_identifiers": true
    },
    "genuine_generated_output": {
      "claim_strength": "compile_coupled_or_generator_coupled",
      "description": "artifacts produced by a real compiler invocation or checked-in generator and tied to reproducible inputs",
      "required_provenance_fields": [
        "surface_id",
        "generator_or_compile_path",
        "input_root",
        "output_path"
      ]
    },
    "synthetic_fixture": {
      "claim_strength": "non_authoritative_until_explicitly_labeled",
      "description": "tracked fixtures or replay artifacts that exist to exercise behavior, regression, or parity without claiming to be live generated truth",
      "allowed_roots": [
        "tests/",
        "showcase/fixtures/"
      ],
      "required_labels": [
        "fixture_family_id",
        "synthetic"
      ]
    },
    "archive_reference": {
      "claim_strength": "historical_only",
      "description": "tracked planning, publication, or redirect material that may retain milestone references but must not drive live product claims",
      "allowed_roots": [
        "tmp/planning/",
        "tmp/github-publish/",
        "tmp/archive/",
        "docs/reference/"
      ],
      "must_not_drive_product_claims": true
    }
  },
  "enforcement_priorities": [
    "generated truth surfaces must reach zero milestone-coded identifiers before product surfaces are considered clean",
    "new product and generated surfaces must use durable objc3c.*.vN identifiers instead of milestone-coded names",
    "synthetic fixtures must be machine-distinguishable from genuine generated outputs before proof claims widen"
  ],
  "classification_contract": "tests/tooling/fixtures/source_hygiene/artifact_authenticity_classification.json"
}
