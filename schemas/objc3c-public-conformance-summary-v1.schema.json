{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.slopjective.local/objc3c-public-conformance-summary-v1.schema.json",
  "title": "ObjC 3 Public Conformance Summary (v1)",
  "description": "Machine-readable public summary that translates live conformance evidence into a third-party-legible report skeleton.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_id",
    "generated_at_utc",
    "status",
    "scorecard_summary_path",
    "public_status",
    "badge",
    "score",
    "headline",
    "report_lines",
    "evidence_paths"
  ],
  "properties": {
    "contract_id": {
      "type": "string",
      "const": "objc3c.public_conformance_reporting.summary.v1"
    },
    "generated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "PASS",
        "FAIL"
      ]
    },
    "source_surface_summary_path": {
      "$ref": "#/$defs/repoPath"
    },
    "schema_surface_summary_path": {
      "$ref": "#/$defs/repoPath"
    },
    "scorecard_summary_path": {
      "$ref": "#/$defs/repoPath"
    },
    "public_status": {
      "type": "string",
      "enum": [
        "pass",
        "caution",
        "blocked"
      ]
    },
    "badge": {
      "type": "string",
      "enum": [
        "claim-ready",
        "provisional",
        "blocked"
      ]
    },
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "headline": {
      "type": "string",
      "minLength": 8
    },
    "report_lines": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "evidence_paths": {
      "type": "array",
      "minItems": 3,
      "items": {
        "$ref": "#/$defs/repoPath"
      }
    }
  },
  "$defs": {
    "repoPath": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._\\-/]+$"
    }
  }
}

