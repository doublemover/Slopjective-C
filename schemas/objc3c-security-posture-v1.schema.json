{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://objc3.dev/schemas/objc3c-security-posture-v1.schema.json",
  "title": "objc3c Security Posture",
  "type": "object",
  "required": [
    "contract_id",
    "generated_at_utc",
    "status",
    "security_state",
    "headline",
    "trust_boundaries",
    "evidence_paths",
    "publication_surface"
  ],
  "properties": {
    "contract_id": {
      "const": "objc3c.security.hardening.posture.v1"
    },
    "generated_at_utc": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "PASS",
        "FAIL"
      ]
    },
    "security_state": {
      "type": "string",
      "enum": [
        "ready",
        "degraded",
        "blocked"
      ]
    },
    "headline": {
      "type": "string"
    },
    "trust_boundaries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "boundary_id",
          "status",
          "source_path"
        ],
        "properties": {
          "boundary_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "PASS",
              "WARN",
              "FAIL"
            ]
          },
          "source_path": {
            "type": "string"
          },
          "detail": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "evidence_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "publication_surface": {
      "type": "object",
      "required": [
        "inspect_security_posture_command",
        "publish_security_advisories_command",
        "validate_security_hardening_command"
      ],
      "properties": {
        "inspect_security_posture_command": {
          "type": "string"
        },
        "publish_security_advisories_command": {
          "type": "string"
        },
        "validate_security_hardening_command": {
          "type": "string"
        },
        "validate_security_hardening_end_to_end_command": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
