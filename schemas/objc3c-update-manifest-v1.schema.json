{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://objc3c.dev/schemas/objc3c-update-manifest-v1.schema.json",
  "title": "objc3c Update Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "contract_id",
    "generated_at_utc",
    "current_version",
    "default_channel",
    "channels",
    "compatibility_report"
  ],
  "properties": {
    "contract_id": { "const": "objc3c.release.operations.update-manifest.v1" },
    "generated_at_utc": { "type": "string" },
    "current_version": { "type": "string" },
    "default_channel": { "type": "string" },
    "channels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["channel_id", "version", "support_status", "artifacts"],
        "properties": {
          "channel_id": { "type": "string" },
          "version": { "type": "string" },
          "support_status": { "type": "string" },
          "artifacts": { "type": "object" }
        }
      }
    },
    "compatibility_report": { "type": "string" }
  }
}
