{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://objc3c.dev/schemas/objc3c-release-sbom-v1.schema.json",
  "title": "objc3c Release SBOM v1",
  "type": "object",
  "required": ["contract_id", "schema_version", "release_manifest_path", "release_payload_digest_sha256", "component_groups"],
  "properties": {
    "contract_id": { "const": "objc3c.release.foundation.sbom.v1" },
    "schema_version": { "const": 1 },
    "release_manifest_path": { "type": "string" },
    "release_payload_digest_sha256": { "type": "string" },
    "component_groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["group_id", "file_count", "entries"],
        "properties": {
          "group_id": { "type": "string" },
          "file_count": { "type": "integer", "minimum": 1 },
          "entries": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["path", "sha256", "byte_count"],
              "properties": {
                "path": { "type": "string" },
                "sha256": { "type": "string" },
                "byte_count": { "type": "integer", "minimum": 0 }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
