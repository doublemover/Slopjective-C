{
  "mode": "m318-c003-new-work-proposal-template-v1",
  "contract_id": "objc3c-governance-new-work-proposal-tooling/m318-c003-v1",
  "consumed_contract_ids": {
    "issue_body_contract": "objc3c-cleanup-planning-packet-issue-template-contract/m317-c001-v1",
    "planning_hygiene": "objc3c-governance-planning-hygiene-policy/m318-b002-v1",
    "exception_process": "objc3c-governance-anti-noise-exception-process/m318-a002-v1",
    "automation_contract": "objc3c-governance-automation-contract/m318-c001-v1"
  },
  "issue_code_pattern": "^M\\d{3}-[A-E]\\d{3}$",
  "title_format": "[{milestone_code}][Lane-{lane}][{short_code}] {title_core} - {kind}",
  "required_issue_fields": [
    "issue_code",
    "title_core",
    "kind",
    "milestone_focus_summary",
    "why_it_matters",
    "acceptance_criteria",
    "primary_implementation_surfaces",
    "dependencies",
    "validation_posture",
    "budget_impact",
    "label_names"
  ],
  "optional_issue_fields": [
    "boundary_note",
    "post_cleanup_dependency_rewrite",
    "design_corrections_folded_in",
    "notes",
    "execution_order",
    "milestone_title",
    "milestone_number",
    "exception_record_id"
  ],
  "execution_order_fields": [
    "cleanup_program_slot",
    "cleanup_program_phase",
    "global_sequence",
    "blocked_by_prior_milestones",
    "direct_issue_blockers",
    "directly_unblocks",
    "instruction"
  ],
  "validation_postures": [
    "shared_acceptance_harness",
    "static_policy_guard",
    "migration_bridge",
    "generator_contract_only"
  ],
  "budget_impact_options": [
    "no_budget_growth",
    "within_existing_budget",
    "requires_exception_record"
  ],
  "render_defaults": {
    "publish_mode": "render-only",
    "write_paths": {
      "issue_body": "issue_body.md",
      "issue_payload": "issue_payload.json",
      "summary": "publication_summary.json"
    }
  },
  "output_dir_default": "tmp/reports/m318/governance/new_work_proposal",
  "next_issue": "M318-D001"
}
